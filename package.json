{
  "name": "@buzztech/boi-ui",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.3.5",
  "description": "BOI Vue 3 TypeScript UI package",
  "type": "module",
  "keywords": [
    "vue",
    "vue3",
    "typescript",
    "boi",
    "edoc",
    "bank-statements"
  ],
  "homepage": "https://github.com/BuzzTechnics/boi-ui#readme",
  "bugs": {
    "url": "https://github.com/BuzzTechnics/boi-ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BuzzTechnics/boi-ui.git"
  },
  "main": "./dist/boi-ui.umd.cjs",
  "module": "./dist/boi-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/boi-ui.js",
      "require": "./dist/boi-ui.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "prepublishOnly": "npm run build",
    "build": "vue-tsc -b && vite build",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "intl-tel-input": "^17.0.21",
    "numeral": "^2.0.6"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/numeral": "^2.0.5",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^15.11.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
